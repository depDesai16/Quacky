# Bandit configuration file
[bandit]
# Exclude test files and virtual environments
exclude_dirs = venv,env,.venv,tests,__pycache__,.git,.github,node_modules

# Test IDs to skip (if needed)
# skips = ['B101', 'B601']

# Test IDs to run
# tests = ['B201', 'B301']

# Severity level: LOW, MEDIUM, HIGH
# level = MEDIUM

# Confidence level: LOW, MEDIUM, HIGH
# confidence = MEDIUM
